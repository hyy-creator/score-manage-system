<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.school.scorebackend.mapper.CourseMapper">
    <select id="selectAll" resultType="com.school.scorebackend.entity.Course">
        SELECT id,course_name courseName,teacher_id teacherId,credit FROM course
        <where>
            <if test="courseName != null and courseName != ''">
                course_name LIKE concat('%',#{courseName},'%')
            </if>
        </where>
    </select>

    <select id="selectByTeacherId" resultType="com.school.scorebackend.entity.Course">
        SELECT id,course_name courseName,credit FROM course WHERE teacher_id=#{teacherId}
    </select>
    <select id="selectByStudentId" resultType="com.school.scorebackend.entity.Course">
        SELECT c.id,c.course_name courseName,u.username teacherName,c.credit
        FROM course c
        LEFT JOIN `user` u ON c.teacher_id=u.id
        LEFT JOIN score s ON c.id=s.course_id
        WHERE s.student_id=#{studentId}
    </select>
    <insert id="insert">
        INSERT INTO course(course_name,teacher_id,credit) VALUES(#{courseName},#{teacherId},#{credit})
    </insert>
    <update id="update">
        UPDATE course SET course_name=#{courseName},teacher_id=#{teacherId},credit=#{credit} WHERE id=#{id}
    </update>
    <delete id="deleteById">
        DELETE FROM course WHERE id=#{id}
    </delete>
</mapper>